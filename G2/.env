# ============================================================================
# Intelligent Medical Assistant - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:12345678@localhost:5432/clinic_db

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================
# Secret key for JWT token signing (MUST be changed in production)
# Generate with: openssl rand -hex 32
SECRET_KEY=09d25e094faa6ca2556c818166b7a9563b93f7099f6f0f4caa6cf63b88e8d3e7

# JWT Algorithm
ALGORITHM=HS256

# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password hashing settings
BCRYPT_ROUNDS=12

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Application name
APP_NAME=Intelligent Medical Assistant

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug mode (true/false)
DEBUG=true

# API version
API_V1_PREFIX=/api/v1

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# ============================================================================
# FILE STORAGE
# ============================================================================
# Base directory for file uploads
UPLOAD_DIR=./storage/uploads

# Medical images directory
MEDICAL_IMAGES_DIR=./storage/medical_images

# Lab reports directory
LAB_REPORTS_DIR=./storage/lab_reports

# Voice recordings directory
VOICE_RECORDINGS_DIR=./storage/voice_recordings

# Report exports directory
REPORT_EXPORTS_DIR=./storage/reports

# Maximum file size (in MB)
MAX_FILE_SIZE_MB=10

# Allowed image formats (comma-separated)
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,dicom

# Allowed document formats (comma-separated)
ALLOWED_DOCUMENT_FORMATS=pdf,docx

# ============================================================================
# AI MODULE SETTINGS
# ============================================================================
# Enable/disable AI features
AI_ENABLED=true

# Speech-to-text settings
STT_ENABLED=true
STT_LANGUAGE=ar  # ar=Arabic, en=English

# Medical NLP settings
NLP_ENABLED=true

# X-ray analysis settings
XRAY_ANALYSIS_ENABLED=true
XRAY_CONFIDENCE_THRESHOLD=0.7

# Skin analysis settings
SKIN_ANALYSIS_ENABLED=true
SKIN_CONFIDENCE_THRESHOLD=0.75

# Lab report interpretation settings
LAB_INTERPRETATION_ENABLED=true

# AI processing timeout (seconds)
AI_PROCESSING_TIMEOUT=30

# ============================================================================
# REPORT GENERATION
# ============================================================================
# Default language for reports (ar, en)
DEFAULT_REPORT_LANGUAGE=ar

# Clinic logo path
CLINIC_LOGO_PATH=./assets/clinic_logo.png

# Report template directory
REPORT_TEMPLATES_DIR=./templates/reports

# ============================================================================
# LOGGING
# ============================================================================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/app.log

# Enable request logging
LOG_REQUESTS=true

# ============================================================================
# PAGINATION
# ============================================================================
# Default page size for paginated responses
DEFAULT_PAGE_SIZE=20

# Maximum page size
MAX_PAGE_SIZE=100

# ============================================================================
# EXTERNAL SERVICES (for production AI integration)
# ============================================================================
# OpenAI API (for speech-to-text and NLP)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4

# AWS S3 (for file storage in production)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=medical-assistant-storage
AWS_REGION=us-east-1

# ============================================================================
# RATE LIMITING (optional)
# ============================================================================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=60

# ============================================================================
# SMTP SETTINGS (for email notifications)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@medical-assistant.com


# =====================================================================
# API GATEWAY PROTECTION
# =====================================================================
# Required header: X-API-KEY
API_ACCESS_KEY="66ba4126aa3b9f227adde3d1e8e143ad0076ad0fdaf861501051eabec00ccc0b"